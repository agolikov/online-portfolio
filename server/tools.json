        "type": "object",
        "required": ["field", "value"],
        "properties": {
          "field": {
            "type": "string",
            "enum": ["name", "title", "location", "email", "website", "github", "linkedin", "summary"]
          },
          "value": { "type": "string" }
        }
      }
    }
  },
