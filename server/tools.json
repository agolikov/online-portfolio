              "location": { "type": "string" },
              "email": { "type": "string" },
              "website": { "type": "string" },
              "github": { "type": "string" },
              "linkedin": { "type": "string" },
              "summary": { "type": "string" }
            }
          }
        }
      }
    }
  },
  {
