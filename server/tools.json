  {
    "type": "function",
    "function": {
      "name": "get_resume",
      "description": "Read the full resume/portfolio data: profile, skills, experience, projects, education, certificates, cover-letter metadata, and behavioral stories. Call this first before answering factual questions or updating anything.",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "update_profile",
      "description": "Replace the entire profile section. Read existing data with get_resume first so unchanged fields are preserved.",
