# PostgreSQL connection used by the Express API and Drizzle.
# Docker Compose does not start a database; set this to an external PostgreSQL URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/online_resume

# App server port for both the Vite frontend and Express API in development.
PORT=3004

# OpenAI-compatible AI provider.
# Leave AI_API_KEY empty to use the fallback cover-letter template and disable chat AI.
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=openai/gpt-oss-120b

# Optional PostHog browser analytics.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
